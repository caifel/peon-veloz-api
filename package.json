{
  "name": "peonveloz-api",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:recreate-migration": "sh scripts/recreate-migration.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio --host 0.0.0.0 --port 4983",
    "db:seed": "bun run src/db/seed.ts",
    "test": "bun test --max-concurrency=1",
    "api:schema": "curl -sf http://localhost:4000/swagger/json > /dev/null && echo '✓ /swagger/json reachable' || (echo '✗ API not reachable — start the Docker dev stack from ops with make up' && exit 1)",
    "whatsapp:worker": "bun --watch src/workers/whatsapp-worker.ts"
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.10",
    "@elysiajs/swagger": "^1.3.1",
    "drizzle-orm": "latest",
    "elysia": "latest",
    "ioredis": "^5.6.0"
  },
  "devDependencies": {
    "@libsql/client": "latest",
    "@types/bun": "latest",
    "drizzle-kit": "latest"
  },
  "module": "src/index.js"
}
